# Copy this file to `.env` (no extension suffix), fill in the values you need,
# and never commit `.env`. This template is safe to commit.
#
# Format: KEY=VALUE per line. No quotes around the value (dotenv handles them).
# Lines starting with # are comments. Empty values are treated as not set.

# ---------------------------------------------------------------
# Hugging Face Hub (optional)
# ---------------------------------------------------------------
# Higher download rate limit & access to gated models.
# Generate a "Read" scope token at: hf.co/settings/tokens
HF_TOKEN=

# ---------------------------------------------------------------
# OpenRouter (required for LLM reranker / generator)
# ---------------------------------------------------------------
# Single key for all four rerankers + generator.
# Generate at: openrouter.ai/keys
OPENROUTER_API_KEY=
